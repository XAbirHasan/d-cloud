# d-cloud environment configuration
# This file is a template — DO NOT put real credentials here
# Run ./d-cloud.sh setup to auto-generate a real .env with secure passwords

# Absolute path to the disk or folder you want to share
DISK_PATH=/path/to/your/disk

# Local port to expose Nextcloud on
PORT=7070

# Nextcloud admin credentials
ADMIN_USER=admin
ADMIN_PASSWORD=change_me

# PostgreSQL password (internal, never exposed publicly)
DB_PASSWORD=change_me

# Space-separated list of trusted domains/IPs
# (auto-populated by setup.sh based on your tunnel type)
TRUSTED_DOMAINS=localhost

# Tunnel type used: tailscale or cloudflare
TUNNEL=tailscale
